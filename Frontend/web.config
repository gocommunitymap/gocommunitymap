<?xml version="1.0" encoding="utf-8"?>
<!--
  IIS + iisnode configuration for Next.js (SSR & Standalone output).

  Standalone deployment layout (copy alongside this web.config):
    server.js          ← .next/standalone/server.js  (generated by Next.js build)
    node_modules\      ← .next/standalone/node_modules\
    .next\static\      ← copied separately from .next\static\
    public\            ← copied separately from public\
    log\               ← created automatically by iisnode

  iisnode docs: https://github.com/tjanczuk/iisnode
-->

<configuration>
  <system.webServer>
    <webSocket enabled="false" />

    <handlers>
      <!-- Route all requests through iisnode → server.js (Next.js entry point) -->
      <add name="iisnode" path="server.js" verb="*" modules="iisnode" />
    </handlers>

    <rewrite>
      <rules>
        <!-- 1. Block node-inspector debug endpoint -->
        <rule name="NodeInspector" patternSyntax="ECMAScript" stopProcessing="true">
          <match url="^server.js\/debug[\/]?" />
        </rule>

        <!-- 2. Serve _next/static/ assets directly from .next/static/ (IIS, no Node overhead).
             Next.js build outputs to .next/static/ but serves via URL /_next/static/. -->
        <rule name="NextStaticAssets" stopProcessing="true">
          <match url="^_next/static/(.*)$" />
          <action type="Rewrite" url=".next/static/{R:1}" />
        </rule>

        <!-- 3. Serve physical public/ files directly (favicon, robots.txt, images, etc.).
             Only applies when the file actually exists on disk. -->
        <rule name="PublicStaticFiles" stopProcessing="true">
          <match url="(.*)" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" />
            <add input="{REQUEST_URI}" pattern="^/server\.js" negate="true" />
          </conditions>
          <action type="None" />
        </rule>

        <!-- 4. All remaining requests → Next.js SSR server -->
        <rule name="DynamicContent">
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="True" />
          </conditions>
          <action type="Rewrite" url="server.js" />
        </rule>
      </rules>

      <!-- Long-lived cache headers on outbound responses for immutable static chunks -->
      <outboundRules>
        <rule name="CacheNextStaticAssets">
          <match serverVariable="RESPONSE_Cache_Control" pattern=".*" />
          <conditions>
            <add input="{REQUEST_URI}" pattern="^/_next/static/" />
          </conditions>
          <action type="Rewrite" value="public, max-age=31536000, immutable" />
        </rule>
      </outboundRules>
    </rewrite>

    <security>
      <requestFiltering>
        <hiddenSegments>
          <!-- Prevent direct browser access to these folders -->
          <add segment="node_modules" />
        </hiddenSegments>
      </requestFiltering>
    </security>

    <!-- Pass Next.js error responses through unchanged -->
    <httpErrors existingResponse="PassThrough" />

    <iisnode
      node_env="production"
      loggingEnabled="true"
      logDirectory="log"
      nodeProcessCommandLine="&quot;C:\Program Files\nodejs\node.exe&quot;"
    />
    <!--
      Optional iisnode tuning:
        watchedFiles="web.config;*.js"  — restart when files change (dev only)
        maxConcurrentRequestsPerProcess — tune for high traffic
        recycleSignal                   — graceful restart signal
    -->
  </system.webServer>
</configuration>



